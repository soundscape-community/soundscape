# Copy this file to .env before running docker compose from svcs/data.
#
# Region examples:
# GEN_REGION=district-of-columbia  # Washington, DC default
# GEN_REGION=united-kingdom        # UK-wide extract
# GEN_REGION=world                 # Full planet extract

# Extra ingest.py flags appended to the ingest container command.
# Ingest mode examples:
# INGEST_MODE=weekly-pbf
# INGEST_MODE=imposm-run
#
# Common local validation mode:
# INGEST_FLAGS=--run-once

# Reuse an existing bootstrap PBF if it is this recent.
# INGEST_PBF_REUSE_DAYS=14

# Optional ntfy.sh notification settings for ingest failures.
# Clear NTFY_TOPIC to disable notifications.
NTFY_TOPIC=SoundscapeDBIngest
